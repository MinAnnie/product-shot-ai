# Database
POSTGRES_DB=product_shot_ai
POSTGRES_USER=product_shot_ai
POSTGRES_PASSWORD=change_me

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# Angular / Public API URL
API_URL=http://localhost:8080

# AI provider
# Use fal for the MVP. Change IMAGE_PROVIDER later when adding another ImageGenerationProvider.
IMAGE_PROVIDER=fal
APP_PUBLIC_BASE_URL=http://localhost:8080
FAL_KEY=your_fal_api_key_here
FAL_BASE_URL=https://fal.run
FAL_ENDPOINT_ID=fal-ai/flux-pro/kontext
FAL_OUTPUT_FORMAT=jpeg
FAL_ASPECT_RATIO=1:1
FAL_SAFETY_TOLERANCE=2
FAL_ENHANCE_PROMPT=true
FAL_GUIDANCE_SCALE=3.5
FAL_NUM_IMAGES=1
